{
  "name": "InvestorInquiry",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Full name of the inquirer"
    },
    "email": {
      "type": "string",
      "description": "Email address"
    },
    "phone": {
      "type": "string",
      "description": "Phone number"
    },
    "investor_type": {
      "type": "string",
      "enum": [
        "institutional",
        "private",
        "family_office",
        "dfi",
        "other"
      ],
      "description": "Type of investor"
    },
    "message": {
      "type": "string",
      "description": "Inquiry message"
    },
    "status": {
      "type": "string",
      "enum": [
        "new",
        "contacted",
        "qualified",
        "closed"
      ],
      "default": "new"
    }
  },
  "required": [
    "name",
    "email"
  ]
}